# Copy this file to `.env` for local development:
#   cp .env.example .env
# then fill in the values below. `.env` is read by `dotenv` (see
# server/env.ts) and should never be committed — check your .gitignore.
#
# On Render, don't use a .env file at all: set these same three variables
# as Environment Variables in the service's dashboard (Settings ->
# Environment). Render assigns PORT itself, so you generally won't set
# PORT there — env.ts falls back to 3000 if it's unset, but Render always
# provides one for a web service.

# Supabase project URL — Project Settings -> API -> Project URL.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase SERVICE ROLE key — Project Settings -> API -> service_role
# secret. This bypasses Row Level Security; it must only ever live on
# this backend, never in client/browser code. Treat it like a password.
SUPABASE_SERVICE_KEY=your-service-role-key

# Local dev port. Render ignores this and injects its own PORT.
PORT=8787
